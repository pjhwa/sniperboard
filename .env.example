# 로컬 환경에 맞게 복사 후 수정: cp .env.example .env
# Docker 환경: BACKEND_URL은 docker-compose.yml에서 자동 설정됩니다 (http://backend:8000).
# 로컬 개발(docker 없이 Next.js dev server 직접 실행 시)에만 아래를 설정하세요.
# BACKEND_URL=http://localhost:5001

# ── 아침 이메일 리포트 (선택) ─────────────────────────────────────────────
# 설정하지 않으면 이메일 전송이 비활성화됩니다 (대시보드는 정상 동작).
# Gmail App Password 발급: Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호
# GMAIL_USER=your@gmail.com
# GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# REPORT_TO=recipient@example.com          # 콤마로 복수 수신자 가능
# DASHBOARD_URL=https://your-server:4000   # 이메일 푸터 '대시보드 바로가기' 링크
